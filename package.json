{
  "name": "swimming-pool-design",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm run build:content",
    "dev": "vite --host 0.0.0.0",
    "build:content": "node scripts/build-public-content.mjs",
    "check:docs": "node scripts/check-docs.mjs",
    "validate:reference": "node scripts/validate-reference-model.mjs",
    "pretest": "npm run build:content",
    "test": "node --test tests/*.test.mjs",
    "typecheck": "tsc --noEmit",
    "test:e2e": "node scripts/viewer-e2e.mjs",
    "clean:reference": "node scripts/clean-reference-dist.mjs",
    "build": "npm run build:content && npm run check:docs && npm run validate:reference && npm test && npm run typecheck && npm run clean:reference && vite build"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "@types/three": "^0.185.1",
    "playwright-core": "^1.61.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "three": "^0.185.1"
  }
}
