{
  "name": "swimming-pool-design",
  "version": "0.3.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "check:docs": "node scripts/check-docs.mjs",
    "validate:reference": "node scripts/validate-reference-model.mjs",
    "test": "node --test tests/*.test.mjs",
    "clean:reference": "node scripts/clean-reference-dist.mjs",
    "build": "npm run check:docs && npm run validate:reference && npm test && npm run clean:reference && vite build"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
